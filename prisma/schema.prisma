// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

enum ContextPackStatus {
  draft
  review
  confirmed
}

// 리서치 단계 명시적 상태 (nullable researchResult 추론 대체)
enum ResearchStatus {
  pending
  completed
  skipped
  failed
}

enum TeamRole {
  owner
  admin
  editor
  viewer
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  memberships    TeamMember[]
  sessions       Session[]
  orgDocuments   OrgDocument[] @relation("OrgDocumentUploader")
  contextPacks   ContextPack[] @relation("ContextPackCreator")
  invitesSent    TeamInvite[]  @relation("InviteSender")
  integrations   IntegrationConnection[]
  exports        ExportDestination[] @relation("ExportDestinationUser")
}

model Team {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members      TeamMember[]
  contextPacks ContextPack[]
  orgDocuments OrgDocument[]
  invites      TeamInvite[]
}

model TeamMember {
  id        String   @id @default(cuid())
  teamId    String
  userId    String
  role      TeamRole @default(editor)
  createdAt DateTime @default(now())

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@index([userId])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model ContextPack {
  id       String            @id @default(cuid())
  issue           String            @default("제목 없는 이슈")
  industry        String?
  purpose         String?
  targetAudience  String?
  status          ContextPackStatus @default(draft)
  version  String            @default("0.1")

  teamId      String?
  team        Team?   @relation(fields: [teamId], references: [id], onDelete: SetNull)
  createdById String?
  createdBy   User?   @relation("ContextPackCreator", fields: [createdById], references: [id], onDelete: SetNull)

  roofMessage    String?
  pillars        String?
  foundation     String?
  objections     String?
  aieoSummary    String?
  riskFlags      String?
  forbiddenTerms String?
  officialTerms  String?

  researchResult String?
  researchedAt   DateTime?
  researchStatus ResearchStatus @default(pending)

  // 파이프라인 lifecycle 타임스탬프
  analyzedAt  DateTime?
  generatedAt DateTime?
  confirmedAt DateTime?

  // 파이프라인 실행 상태 (실패 재개·진행률 UI용)
  pipelineRunningStep String?
  pipelineError       String?
  pipelineErrorStep   String?

  gateMessageReviewed Boolean @default(false)
  gateNoConfidential  Boolean @default(false)
  gateNumbersVerified Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  files SourceFile[]

  exportDestinations ExportDestination[]

  @@index([teamId])
  @@index([updatedAt])
  @@index([status, updatedAt])
}

model SourceFile {
  id            String      @id @default(cuid())
  contextPackId String
  contextPack   ContextPack @relation(fields: [contextPackId], references: [id], onDelete: Cascade)

  filename      String
  mimeType      String
  sizeBytes     Int
  extractedText String

  docType  String?
  topic    String?
  claim    String?
  numbers  String?
  terms    String?
  audience String?
  risk     String?

  analyzedAt DateTime?
  createdAt  DateTime  @default(now())

  chunks DocumentChunk[]

  @@index([contextPackId])
}

model DocumentChunk {
  id           String     @id @default(cuid())
  sourceFileId String
  sourceFile   SourceFile @relation(fields: [sourceFileId], references: [id], onDelete: Cascade)
  // Pack 단위 RAG 조회 최적화 (sourceFile 조인 없이 필터)
  contextPackId String

  chunkIndex Int
  text       String
  embedding  String
  model      String

  createdAt DateTime @default(now())

  @@unique([sourceFileId, chunkIndex])
  @@index([sourceFileId])
  @@index([contextPackId])
}

// 팩 간 공유 조직 문서 라이브러리 (F-05)
model OrgDocument {
  id          String @id @default(cuid())
  teamId      String
  team        Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)
  uploadedById String?
  uploadedBy  User?  @relation("OrgDocumentUploader", fields: [uploadedById], references: [id], onDelete: SetNull)

  title         String
  description   String?
  filename      String
  mimeType      String
  sizeBytes     Int
  extractedText String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  chunks OrgDocumentChunk[]

  @@index([teamId])
}

model OrgDocumentChunk {
  id            String      @id @default(cuid())
  orgDocumentId String
  orgDocument   OrgDocument @relation(fields: [orgDocumentId], references: [id], onDelete: Cascade)

  chunkIndex Int
  text       String
  embedding  String
  model      String

  createdAt DateTime @default(now())

  @@unique([orgDocumentId, chunkIndex])
  @@index([orgDocumentId])
}

// 팀 초대 링크 (F-08)
model TeamInvite {
  id          String    @id @default(cuid())
  teamId      String
  team        Team      @relation(fields: [teamId], references: [id], onDelete: Cascade)
  email       String
  role        TeamRole  @default(editor)
  token       String    @unique
  invitedById String
  invitedBy   User      @relation("InviteSender", fields: [invitedById], references: [id], onDelete: Cascade)
  expiresAt   DateTime
  acceptedAt  DateTime?
  createdAt   DateTime  @default(now())

  @@index([teamId])
  @@index([email])
}

enum IntegrationProvider {
  google_drive
  notion
}

// 사용자별 외부 서비스 OAuth 연결 (Google Drive, Notion)
model IntegrationConnection {
  id           String              @id @default(cuid())
  userId       String
  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider     IntegrationProvider
  accessToken  String
  refreshToken String?
  expiresAt    DateTime?
  // JSON: workspaceName, defaultFolderId, notionDatabaseId, notionParentPageId, titlePropertyName
  metadata     String?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  @@unique([userId, provider])
  @@index([userId])
}

// Context Pack 외부 저장 이력 (재보내기 시 업데이트)
model ExportDestination {
  id            String              @id @default(cuid())
  contextPackId String
  contextPack   ContextPack         @relation(fields: [contextPackId], references: [id], onDelete: Cascade)
  provider      IntegrationProvider
  externalId    String
  url           String
  format        String              @default("markdown")
  exportedById  String?
  exportedBy    User?               @relation("ExportDestinationUser", fields: [exportedById], references: [id], onDelete: SetNull)
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  @@unique([contextPackId, provider])
  @@index([contextPackId])
}
