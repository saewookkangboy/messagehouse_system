{
  "name": "messagehouse-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:reset": "prisma migrate reset",
    "db:pg:up": "docker compose up -d",
    "db:pg:migrate": "tsx scripts/migrate-sqlite-to-pg.ts --reset-pg",
    "db:neon:setup": "tsx scripts/setup-neon.ts",
    "db:generate:pg": "prisma generate --schema prisma/schema.postgresql.prisma",
    "test:rag-regression": "tsx scripts/rag-regression-diff.ts",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.109.1",
    "@google/genai": "^2.10.0",
    "@prisma/adapter-better-sqlite3": "^7.8.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "kordoc": "^3.5.4",
    "mammoth": "^1.12.0",
    "next": "16.2.10",
    "pdf-parse": "^2.4.5",
    "pg": "^8.22.0",
    "prisma": "^7.8.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.4.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "tsx": "^4.22.4",
    "typescript": "^5",
    "vitest": "^4.1.9"
  }
}
